        "reference/observe",
        "reference/act",
        "reference/record",
        "reference/perf",
        "reference/journey",
        "reference/device",
        "reference/diagnostics"
      ]
    },
    {
      "group": "Releases",
      "pages": [
        "changelog/index"
      ]
    }
