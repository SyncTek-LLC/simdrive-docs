  "anchors": [
    {
      "name": "Quickstart",
      "icon": "rocket",
      "url": "quickstart"
    },
    {
      "name": "Concepts",
      "icon": "book",
      "url": "concepts"
    },
    {
      "name": "Guides",
      "icon": "list-check",
      "url": "guides"
    },
    {
      "name": "Pricing",
      "icon": "credit-card",
      "url": "https://simdrive.dev/pricing"
    }
  ],
  "navigation": [
