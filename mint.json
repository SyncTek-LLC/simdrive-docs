{
  "$schema": "https://mintlify.com/schema.json",
  "name": "SimDrive",
  "logo": {
    "light": "/logo/wordmark.svg",
    "dark": "/logo/wordmark-dark.svg",
    "href": "https://simdrive.dev"
  },
  "favicon": "/logo/sd-favicon.svg",
  "colors": {
    "primary": "#22D3EE",
    "light": "#67E8F9",
    "dark": "#0891B2",
    "anchors": {
      "from": "#22D3EE",
