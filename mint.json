    "og:site_name": "SimDrive",
    "og:type": "website",
    "twitter:card": "summary_large_image",
    "twitter:site": "@synctekio"
  },
  "topbarCtaButton": {
    "name": "Get SimDrive",
    "url": "https://simdrive.dev/pricing"
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/SyncTek-LLC/simdrive"
    },
    {
      "name": "PyPI",
      "url": "https://pypi.org/project/simdrive/"
    }
  ],
  "primaryTab": {
    "name": "Docs"
  },
  "tabs": [
    {
      "name": "Reference",
      "url": "reference"
    },
    {
      "name": "Changelog",
      "url": "changelog"
    }
